# Kopiere diese Datei zu ".env" und trage deinen Finnhub-Key ein.
# Kostenlosen Key holen: https://finnhub.io/register

FINNHUB_API_KEY=dein_finnhub_key_hier

# Optional: Startkapital (Spielgeld) in USD. Standard 10000.
START_CASH=10000

# Optional: Port (Render setzt diesen automatisch via $PORT)
PORT=8000

# Optional: KI-Analyst (Anthropic). Ohne Key läuft nur der statistische Analyst.
# Key holen: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANALYST_MODEL=claude-opus-4-8
